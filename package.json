{
  "name": "codexapp",
  "version": "0.1.87",
  "description": "A lightweight web interface for Codex that runs on top of the Codex app-server, allowing remote access from any browser",
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "license": "MIT",
  "author": "Pavel Voronin, Igor Levochkin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/friuns2/codexui.git"
  },
  "homepage": "https://github.com/friuns2/codexui#readme",
  "bugs": {
    "url": "https://github.com/friuns2/codexui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "codex",
    "openai",
    "web-ui",
    "remote",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "codexapp": "dist-cli/index.js",
    "codexui": "dist-cli/index.js"
  },
  "files": [
    "dist/",
    "dist-cli/",
    "scripts/dev.cjs",
    "scripts/fix-pty-native-build.cjs"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "esbuild",
      "node-pty",
      "protobufjs"
    ]
  },
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:open": "pnpm run build:cli && sh -c 'pnpm run dev & VPID=$!; node dist-cli/index.js --open-project \"${1:-.}\"; wait $VPID' --",
    "build:frontend": "vue-tsc --noEmit && vite build",
    "build:cli": "tsup",
    "build": "pnpm run build:frontend && pnpm run build:cli",
    "postinstall": "node scripts/fix-pty-native-build.cjs",
    "test": "pnpm run build && node scripts/test-thread-auto-title.mjs && node scripts/test-web-push-notifications.mjs && node scripts/test-codexui-runtime-config.mjs && node scripts/test-codexui-transcription-override.mjs && node scripts/test-codexui-auth-shell-cache.mjs && node scripts/test-codexui-browser-startup-hardening.mjs",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser-annotation": "node scripts/test-browser-annotation-endpoints.cjs",
    "pack:browser-annotation": "node scripts/package-browser-annotation-extension.cjs && node extension/browser-annotation/dev/validate-extension.mjs --production dist/browser-annotation-extension/unpacked",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build",
    "profile:browser": "node scripts/profile-browser-runtime.cjs",
    "profile:thread": "PROFILE_ROUTE='#/thread/019da7c0-4e12-7a91-837c-f7c11cc8ab6c' node scripts/profile-browser-runtime.cjs"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.1",
    "@composio/client": "0.1.0-alpha.66",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "firebase": "^12.2.1",
    "highlight.js": "^11.11.1",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.4",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-istanbul": "4.1.6",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "4.1.6",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.0"
  }
}
