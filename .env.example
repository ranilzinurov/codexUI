CODEXUI_API_PERF_LOGGING=0
CODEXUI_API_PERF_MS_THRESHOLD=250
CODEXUI_API_PERF_BODY_MB_THRESHOLD=1
CODEXUI_TRANSCRIBE_PROVIDER=
CODEXUI_TRANSCRIBE_BASE_URL=
CODEXUI_TRANSCRIBE_MODEL=

# Browser-visible Firebase web app settings for GitHub OAuth popup login.
# These VITE_* values are bundled into the frontend. Keep real server secrets
# in server-only CODEXUI_* env vars instead.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
